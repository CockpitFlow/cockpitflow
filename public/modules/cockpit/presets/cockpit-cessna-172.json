{
  "name": "Cessna 172S Skyhawk",
  "author": "CockpitFlow",
  "aircraft": "C172S",
  "version": 2,
  "grid": { "cols": 12, "rows": 8 },
  "theme": {
    "bg": "#111317",
    "panel": "#1c1e22",
    "accent": "#4a9eff",
    "green": "#44dd66",
    "amber": "#ddaa44",
    "red": "#ee4444"
  },
  "components": [
    {
      "id": "throttle",
      "type": "lever",
      "col": 1, "row": 1, "w": 1, "h": 7,
      "label": "THR",
      "cmd": "THROTTLE",
      "color": "default",
      "default": 0
    },
    {
      "id": "mixture",
      "type": "lever",
      "col": 2, "row": 1, "w": 1, "h": 7,
      "label": "MIX",
      "cmd": "MIXTURE",
      "color": "red",
      "default": 1
    },
    {
      "id": "carb_heat",
      "type": "lever",
      "col": 3, "row": 1, "w": 1, "h": 7,
      "label": "CARB",
      "cmd": "CARB_HEAT",
      "color": "amber",
      "default": 0
    },
    {
      "id": "flaps",
      "type": "flaps",
      "col": 4, "row": 1, "w": 1, "h": 5,
      "label": "FLAPS",
      "cmd": "FLAPS",
      "detents": [
        { "value": 0, "label": "UP" },
        { "value": 0.33, "label": "10°" },
        { "value": 0.66, "label": "20°" },
        { "value": 1, "label": "FULL" }
      ]
    },
    {
      "id": "trim",
      "type": "trim",
      "col": 4, "row": 6, "w": 1, "h": 2,
      "label": "TRIM",
      "cmd": "TRIM",
      "step": 0.03
    },
    {
      "id": "yoke",
      "type": "yoke",
      "col": 5, "row": 1, "w": 5, "h": 7,
      "modes": ["touch", "gyro"],
      "sensitivity": 1,
      "deadzone": 0.05,
      "cmd_ail": "AILERON",
      "cmd_elv": "ELEVATOR"
    },
    {
      "id": "ias",
      "type": "gauge",
      "col": 10, "row": 1, "w": 3, "h": 1,
      "label": "IAS",
      "dataref": "AIRSPEED",
      "unit": "KTS",
      "format": "int",
      "thresholds": [
        { "below": 45, "color": "red" },
        { "below": 60, "color": "amber" }
      ]
    },
    {
      "id": "alt",
      "type": "gauge",
      "col": 10, "row": 2, "w": 3, "h": 1,
      "label": "ALT",
      "dataref": "ALTITUDE",
      "unit": "FT",
      "format": "int",
      "thresholds": []
    },
    {
      "id": "vs",
      "type": "gauge",
      "col": 10, "row": 3, "w": 3, "h": 1,
      "label": "VS",
      "dataref": "VS",
      "unit": "FPM",
      "format": "signed",
      "thresholds": [
        { "below": -1000, "color": "red" },
        { "below": -500, "color": "amber" }
      ]
    },
    {
      "id": "hdg",
      "type": "gauge",
      "col": 10, "row": 4, "w": 3, "h": 1,
      "label": "HDG",
      "dataref": "HEADING",
      "unit": "°",
      "format": "heading",
      "thresholds": []
    },
    {
      "id": "rpm",
      "type": "gauge",
      "col": 10, "row": 5, "w": 3, "h": 1,
      "label": "RPM",
      "dataref": "RPM",
      "unit": "",
      "format": "int",
      "thresholds": []
    },
    {
      "id": "fuel",
      "type": "fuel-selector",
      "col": 10, "row": 6, "w": 3, "h": 1,
      "label": "FUEL",
      "cmd": "FUEL_SEL",
      "positions": [
        { "value": 1, "label": "L" },
        { "value": 2, "label": "BOTH" },
        { "value": 3, "label": "R" }
      ],
      "default": 2
    },
    {
      "id": "radio_com1",
      "type": "radio",
      "col": 10, "row": 7, "w": 3, "h": 1,
      "radio_type": "com",
      "label": "COM1",
      "dataref": "COM1_FREQ",
      "default_freq": "121.800"
    },
    {
      "id": "magneto",
      "type": "magneto",
      "col": 1, "row": 8, "w": 2, "h": 1,
      "label": "MAG",
      "cmd": "MAGNETO",
      "positions": ["OFF", "R", "L", "B", "ST"],
      "spring_back": { "from": 4, "to": 3 },
      "default": 3
    },
    {
      "id": "master_alt",
      "type": "toggle",
      "col": 3, "row": 8, "w": 1, "h": 1,
      "label": "ALT",
      "cmd": "MASTER_ALT",
      "style": "red"
    },
    {
      "id": "master_bat",
      "type": "toggle",
      "col": 4, "row": 8, "w": 1, "h": 1,
      "label": "BAT",
      "cmd": "MASTER_BATTERY",
      "style": "red"
    },
    {
      "id": "fuel_pump",
      "type": "toggle",
      "col": 5, "row": 8, "w": 1, "h": 1,
      "label": "PUMP",
      "cmd": "FUEL_PUMP",
      "style": "blue"
    },
    {
      "id": "beacon",
      "type": "toggle",
      "col": 6, "row": 8, "w": 1, "h": 1,
      "label": "BCN",
      "cmd": "BEACON",
      "style": "blue"
    },
    {
      "id": "landing_light",
      "type": "toggle",
      "col": 7, "row": 8, "w": 1, "h": 1,
      "label": "LAND",
      "cmd": "LANDING_LIGHT",
      "style": "blue"
    },
    {
      "id": "taxi_light",
      "type": "toggle",
      "col": 8, "row": 8, "w": 1, "h": 1,
      "label": "TAXI",
      "cmd": "TAXI_LIGHT",
      "style": "blue"
    },
    {
      "id": "nav_light",
      "type": "toggle",
      "col": 9, "row": 8, "w": 1, "h": 1,
      "label": "NAV",
      "cmd": "NAV_LIGHT",
      "style": "blue"
    },
    {
      "id": "strobe",
      "type": "toggle",
      "col": 10, "row": 8, "w": 1, "h": 1,
      "label": "STRB",
      "cmd": "STROBE",
      "style": "blue"
    },
    {
      "id": "pitot",
      "type": "toggle",
      "col": 11, "row": 8, "w": 1, "h": 1,
      "label": "PITOT",
      "cmd": "PITOT_HEAT",
      "style": "blue"
    },
    {
      "id": "avionics",
      "type": "toggle",
      "col": 12, "row": 8, "w": 1, "h": 1,
      "label": "AVIO",
      "cmd": "AVIONICS_MASTER",
      "style": "blue"
    }
  ]
}
