{
  "$schema": "mapping",
  "version": 1,
  "id": "esp32-radio-cessna172",
  "name": "ESP32 Radio Panel → Cessna 172",
  "author": "cockpitflow",
  "description": "WiFi radio panel with COM/NAV encoders and 7-segment displays for a Cessna 172.",
  "device_profile": "esp32-radio-panel",
  "aircraft_profile": "cessna-172-skyhawk",
  "mappings": [
    { "pin": 13, "action": "event", "target": "COM_RADIO_WHOLE_INC", "options": { "event_dec": "COM_RADIO_WHOLE_DEC" } },
    { "pin": 15, "action": "event", "target": "COM_RADIO_FRACT_INC", "options": { "event_dec": "COM_RADIO_FRACT_DEC" } },
    { "pin": 17, "action": "event", "target": "COM_STBY_RADIO_SWAP" },
    { "pin": 25, "action": "event", "target": "NAV1_RADIO_WHOLE_INC", "options": { "event_dec": "NAV1_RADIO_WHOLE_DEC" } },
    { "pin": 33, "action": "event", "target": "NAV1_STBY_RADIO_SWAP" },
    { "pin": 34, "action": "event", "target": "HEADING_BUG_INC", "options": { "event_dec": "HEADING_BUG_DEC" } },
    { "pin": 36, "action": "set_var", "target": "NAV OBS:1", "options": { "range": [0, 360] } },

    { "pin": 2, "action": "read_var", "target": "COM ACTIVE FREQUENCY:1" },
    { "pin": 4, "action": "read_var", "target": "COM STANDBY FREQUENCY:1" },
    { "pin": 5, "action": "read_var", "target": "NAV ACTIVE FREQUENCY:1" }
  ]
}
