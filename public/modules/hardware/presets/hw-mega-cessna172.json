{
  "$schema": "mapping",
  "version": 1,
  "id": "mega-cessna172-full",
  "name": "Arduino Mega → Cessna 172 (Full Setup)",
  "author": "cockpitflow",
  "description": "Complete mapping for a Cessna 172 cockpit built with an Arduino Mega. Covers switches, encoders, pots, and indicator LEDs.",
  "device_profile": "arduino-mega-cockpit",
  "aircraft_profile": "cessna-172-skyhawk",
  "mappings": [
    { "pin": 2, "action": "event", "target": "TOGGLE_MASTER_BATTERY" },
    { "pin": 3, "action": "event", "target": "TOGGLE_MASTER_ALTERNATOR" },
    { "pin": 5, "action": "event", "target": "FUEL_PUMP" },
    { "pin": 6, "action": "event", "target": "PITOT_HEAT_TOGGLE" },
    { "pin": 7, "action": "event", "target": "GEAR_TOGGLE" },
    { "pin": 8, "action": "event", "target": "TOGGLE_LANDING_LIGHTS" },
    { "pin": 9, "action": "event", "target": "TOGGLE_TAXI_LIGHTS" },
    { "pin": 10, "action": "event", "target": "TOGGLE_NAV_LIGHTS" },
    { "pin": 11, "action": "event", "target": "STROBES_TOGGLE" },
    { "pin": 12, "action": "event", "target": "TOGGLE_BEACON_LIGHTS" },
    { "pin": 14, "action": "event", "target": "PARKING_BRAKES" },
    { "pin": 15, "action": "event", "target": "FLAPS_INCR" },
    { "pin": 16, "action": "event", "target": "FLAPS_DECR" },
    { "pin": 17, "action": "event", "target": "AP_MASTER" },
    { "pin": 18, "action": "event", "target": "AP_HDG_HOLD" },
    { "pin": 19, "action": "event", "target": "AP_ALT_HOLD" },
    { "pin": 20, "action": "event", "target": "AP_NAV1_HOLD" },
    { "pin": 21, "action": "event", "target": "AP_APR_HOLD" },
    { "pin": 22, "action": "event", "target": "AP_VS_HOLD" },

    { "pin": 24, "action": "event", "target": "HEADING_BUG_INC", "options": { "event_dec": "HEADING_BUG_DEC" } },
    { "pin": 26, "action": "event", "target": "AP_ALT_VAR_INC", "options": { "event_dec": "AP_ALT_VAR_DEC" } },
    { "pin": 28, "action": "event", "target": "AP_VS_VAR_INC", "options": { "event_dec": "AP_VS_VAR_DEC" } },
    { "pin": 30, "action": "event", "target": "COM_RADIO_WHOLE_INC", "options": { "event_dec": "COM_RADIO_WHOLE_DEC" } },
    { "pin": 32, "action": "event", "target": "COM_RADIO_FRACT_INC", "options": { "event_dec": "COM_RADIO_FRACT_DEC" } },
    { "pin": 34, "action": "set_var", "target": "NAV OBS:1", "options": { "range": [0, 360] } },
    { "pin": 36, "action": "set_var", "target": "KOHLSMAN SETTING HG", "options": { "range": [28.0, 31.5] } },

    { "pin": 40, "action": "read_var", "target": "GEAR CENTER POSITION", "options": { "threshold": 0.5 } },
    { "pin": 41, "action": "read_var", "target": "GEAR LEFT POSITION", "options": { "threshold": 0.5 } },
    { "pin": 42, "action": "read_var", "target": "GEAR RIGHT POSITION", "options": { "threshold": 0.5 } },
    { "pin": 43, "action": "read_var", "target": "AUTOPILOT MASTER", "options": { "threshold": 0.5 } },
    { "pin": 46, "action": "read_var", "target": "MASTER BATTERY SWITCH", "options": { "threshold": 0.5 } },

    { "pin": "A0", "action": "set_var", "target": "GENERAL ENG THROTTLE LEVER POSITION:1", "options": { "range": [0, 100], "curve": "linear", "invert": false } },
    { "pin": "A2", "action": "set_var", "target": "GENERAL ENG MIXTURE LEVER POSITION:1", "options": { "range": [0, 100], "curve": "linear", "invert": false } },
    { "pin": "A5", "action": "set_var", "target": "ELEVATOR TRIM POSITION", "options": { "range": [-10, 10], "curve": "linear", "invert": false } }
  ]
}
