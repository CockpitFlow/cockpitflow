{
  "$schema": "mapping",
  "version": 1,
  "id": "nano-cessna172-basic",
  "name": "Arduino Nano → Cessna 172 (Basic)",
  "author": "community",
  "description": "Basic cockpit mapping: throttle, mixture, flaps, battery, lights.",
  "device_profile": "arduino-nano-basic",
  "aircraft_profile": "cessna-172-skyhawk",
  "mappings": [
    { "pin": 2, "action": "event", "target": "TOGGLE_MASTER_BATTERY" },
    { "pin": 3, "action": "event", "target": "MAGNETO_BOTH" },
    { "pin": 4, "action": "event", "target": "FLAPS_INCR" },
    { "pin": 5, "action": "event", "target": "FLAPS_DECR" },
    { "pin": 6, "action": "event", "target": "TOGGLE_LANDING_LIGHTS" },
    { "pin": 7, "action": "event", "target": "PARKING_BRAKES" },
    { "pin": 8, "action": "event", "target": "AP_MASTER" },
    { "pin": "A0", "action": "set_var", "target": "GENERAL ENG THROTTLE LEVER POSITION:1", "options": { "range": [0, 100] } },
    { "pin": "A1", "action": "set_var", "target": "GENERAL ENG MIXTURE LEVER POSITION:1", "options": { "range": [0, 100] } },
    { "pin": 13, "action": "read_var", "target": "MASTER BATTERY SWITCH", "options": { "threshold": 0.5 } }
  ]
}
