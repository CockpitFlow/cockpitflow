{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CockpitFlow",
  "version": "1.0.0",
  "identifier": "com.cockpitflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5176",
    "beforeDevCommand": "npm run dev -- --port 5176",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CockpitFlow — Cockpit Companion",
        "width": 900,
        "height": 600,
        "minWidth": 700,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
